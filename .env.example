# ==============================
# AI News Agent - Env Template
# ==============================

# DeepSeek API (用于文章打分与汇总)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Gemini / Google API (用于小红书文案与卡片数据)
GOOGLE_API_KEY=

# 评分阈值 (>= 此分数才进入汇总)
SCORE_THRESHOLD=7

# 抓取时间窗口（小时）
FETCH_HOURS=24

# 可选：代理
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# 可选：小红书 MCP
XHS_MCP_URL=http://127.0.0.1:18060/mcp
XHS_MCP_RETRIES=1
